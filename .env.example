# true 이면 Supabase 호출 없이 파싱 결과만 stdout JSON 으로 출력
SKIP_SUPABASE=false

# Site (legacy admin)
BASE_URL=https://example.com
LOGIN_PATH=/admin/login/login_ok.php
LIST_OK_PATH=/admin/apply/edu_apply_list_ok.php

ADMIN_USER=
ADMIN_PASSWORD=

# Form field names (adjust to match the real login form)
LOGIN_USER_FIELD=user_id
LOGIN_PASS_FIELD=user_pw
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Impka3p5ZGhvbnZhc3lqampmdmtpIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc2NzU3NDA2NiwiZXhwIjoyMDgzMTUwMDY2fQ.pRa3yfj06_-jeZk_IzdMapuaTDRykYYLXs8gM7TJHnY
# Optional: extra POST fields as JSON, e.g. {"mode":"login"}
# LOGIN_EXTRA_FIELDS_JSON={}

# list_ok.php is usually GET; if yours expects POST body, set LIST_HTTP_METHOD=POST and LIST_POST_BODY_JSON={"page":1}
# LIST_HTTP_METHOD=GET
# LIST_POST_BODY_JSON=

# First matching <table> uses TABLE_SELECTOR (BeautifulSoup selector)
# TABLE_SELECTOR=table.board_list

# Column (header key after normalization) used as stable external_id for upsert
# ROW_ID_HEADER=신청번호

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Target table (create with schema.sql)
SUPABASE_TABLE=crawl_rows

# VERIFY_TLS=false

# 각 회원 seq 로 member_form.html 을 GET 해서 메모만 읽어 row["sub"]["메모"] 에 넣음
# FETCH_MEMBER_MEMO=false
# MEMBER_FORM_PATH=/admin/member/member_form.html
# MEMBER_FORM_EXTRA_QUERY=select_key=&input_key=&search=&sort=member&type=P&page=1
# MEMO_REQUEST_DELAY_MS=0

# true 이면 members_crawled 전용: page=1..N 순회, 번호=1 인 행이 나오는 페이지까지, RPC upsert (seq 충돌 시 갱신)
# SAVE_TO_MEMBERS_CRAWLED=false
# MAX_LIST_PAGES=2000
# 회원 목록 page=1,2,… 저장 후 다음 페이지 요청 전 대기(초). 0이면 바로 다음 페이지
# MEMBER_LIST_PAGE_DELAY_SECONDS=30
# 한 바퀴 끝(빈 페이지·번호=1) 후 다시 1페이지부터 무한 반복 (로컬 python -m crawler.run)
# CRAWL_LOOP_FOREVER=false
# 라운드 사이 대기 초
# LOOP_SLEEP_SECONDS=10

# 교육 목록 로컬 크롤 (python -m crawler.edu_crawl_local --loop) 무한 라운드
# EDU_CRAWL_LOOP=false

# 교육 목록 + 신청자 (Edge 없이 RPC, 순서: 목록 라운드 후 applicants 단계)
# python -m crawler.edu_crawl_local --delay 10
# python -m crawler.edu_crawl_local --skip-applicants  # 목록만
# EDU_LIST_PATH=/admin/edu/edu_list.html?select_key=&input_key=&search=&cate=&el_state=-1&el_area=&el_code=&el_startdate=&el_enddate=&page=1
# EDU_APPLY_LIST_TEMPLATE=/admin/edu/edu_apply_list.html?el_seq={el_seq}
# EDU_APPLICANT_TABLE_SELECTOR=table.list_table
# EDU_PAGES_PER_RUN=1
# 신청자 목록 page 간 대기(초). 0이면 연속 요청
# EDU_APPLICANT_PAGE_DELAY_SECONDS=30
# 신청자: 교육 한 건 처리 후 다음 교육(seq) 요청 전 대기(초)
# EDU_APPLICANT_EDU_DELAY_SECONDS=2
# true 이면 신청자만 Edge 처럼 edu_applicant_crawl_progress 사용 (--applicants-progress-mode 와 동일)
# EDU_APPLICANTS_PROGRESS_MODE=false
# 진행 모드일 때만: run_applicants_phase 연속 호출 횟수
# EDU_APPLICANTS_ROUNDS=1
